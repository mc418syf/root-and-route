{% if recommendations.performed? and recommendations.products_count > 0 %}
<section class="section" style="background:var(--rr-paper);border-top:1px solid var(--rr-border);">
  <div class="wrap">
    <div class="section-head">
      <h2 class="section-head__title">{{ section.settings.title | default: 'You May Also Love' }}</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat({{ section.settings.products_to_show | default: 4 }},1fr);gap:20px;">
      {% for product in recommendations.products %}
        <a href="{{ product.url }}" style="display:block;border:1px solid var(--rr-border);border-radius:4px;overflow:hidden;">
          <div style="aspect-ratio:1;overflow:hidden;background:var(--rr-paper);">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" width="400" height="400" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
            {% endif %}
          </div>
          <div style="padding:14px 16px 18px;">
            <p style="font-family:var(--rr-serif);font-weight:300;font-size:1rem;color:var(--rr-ink);margin-bottom:6px;">{{ product.title }}</p>
            <p style="font-family:var(--rr-sans);font-size:13px;color:var(--rr-forest);">{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "You May Also Love" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 4 }
  ]
}
{% endschema %}
