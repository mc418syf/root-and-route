<section class="rr-section rr-section--paper">
  <div class="rr-container">
    {% render 'rr-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, center: false %}
    <div class="rr-portfolio">
      {% for block in section.blocks %}
        <article class="rr-portfolio-card" {{ block.shopify_attributes }}>
          <div class="rr-portfolio-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 640 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {% render 'rr-placeholder' %}
            {% endif %}
          </div>
          <div>
            <div class="rr-meta">{{ block.settings.meta }}</div>
            <h3 class="rr-h3">{{ block.settings.title }}</h3>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Portfolio display",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Portfolio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product display with the treatment of art photography." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Clean natural light, close material texture, tactile structure, and the feeling of resistance in every opening moment." }
  ],
  "blocks": [
    {
      "type": "work",
      "name": "Work",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Beauty / Rigid box" },
        { "type": "text", "id": "title", "label": "Title", "default": "Magnetic reveal box" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Portfolio display",
      "blocks": [
        { "type": "work" },
        { "type": "work", "settings": { "title": "Frosted perfume sleeve", "meta": "Fragrance / Specialty paper" } },
        { "type": "work", "settings": { "title": "Drawer-style gift set", "meta": "Lifestyle / Structural engineering" } },
        { "type": "work", "settings": { "title": "Book-form presentation box", "meta": "Beauty / Magnetic closure" } }
      ]
    }
  ]
}
{% endschema %}
