<div class="collection-header section" style="background:var(--rr-paper);border-bottom:1px solid var(--rr-border);">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Collection</p>
      <h1 class="section-head__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p class="section-head__sub">{{ collection.description }}</p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Header",
  "settings": []
}
{% endschema %}
