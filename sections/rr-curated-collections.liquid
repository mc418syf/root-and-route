<section class="rr-section">
  <div class="rr-container">
    {% render 'rr-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, center: true %}
    <div class="rr-grid-3">
      {% for block in section.blocks %}
        <a class="rr-collection-card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div class="rr-collection-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 760 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {% render 'rr-placeholder' %}
            {% endif %}
          </div>
          <div class="rr-collection-card__body">
            <div class="rr-meta">{{ block.settings.meta }}</div>
            <h3 class="rr-h3">{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Curated collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Named by material, structure, and aesthetic language." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Guide buyers into tactile product families that feel designed, not merely manufactured." }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Frosted specialty paper" },
        { "type": "text", "id": "title", "label": "Title", "default": "The Frost Collection" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Soft white texture, diffused reflection, and a clean natural-light finish." },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Curated collections",
      "blocks": [
        { "type": "collection", "settings": { "title": "The Frost Collection", "meta": "White frost tactility" } },
        { "type": "collection", "settings": { "title": "The Linear Collection", "meta": "Minimal modern lines", "text": "Precise folds, quiet surfaces, and restrained geometry for contemporary brands." } },
        { "type": "collection", "settings": { "title": "The Monolith Collection", "meta": "Rigid book-style boxes", "text": "Substantial block forms, magnetic closure, and the pleasure of a weighted reveal." } }
      ]
    }
  ]
}
{% endschema %}
