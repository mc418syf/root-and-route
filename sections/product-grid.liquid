<section class="section">
  <div class="wrap">
    {% paginate collection.products by 12 %}
      <div class="product-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {% for product in collection.products %}
          <a class="product-card" href="{{ product.url }}" style="display:block;border:1px solid var(--rr-border);border-radius:4px;overflow:hidden;transition:transform .2s,box-shadow .2s;">
            <div style="aspect-ratio:3/4;overflow:hidden;background:var(--rr-paper);">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" width="600" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
              {% else %}
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--rr-forest);opacity:.3;">
                  {% render 'icon-leaf', width: 48, height: 60 %}
                </div>
              {% endif %}
            </div>
            <div style="padding:16px 18px 20px;">
              <p style="font-family:var(--rr-sans);font-size:11px;letter-spacing:.06em;color:var(--rr-muted);margin-bottom:6px;text-transform:uppercase;">{{ product.type }}</p>
              <h3 style="font-family:var(--rr-serif);font-weight:300;font-size:1.15rem;color:var(--rr-ink);margin-bottom:8px;">{{ product.title }}</h3>
              <p style="font-family:var(--rr-sans);font-size:14px;color:var(--rr-forest);">{{ product.price | money }}</p>
            </div>
          </a>
        {% else %}
          <p style="font-family:var(--rr-sans);color:var(--rr-muted);">No products found in this collection.</p>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div style="display:flex;justify-content:center;gap:12px;margin-top:56px;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="btn btn--secondary">← Previous</a>
          {% endif %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="btn btn--secondary">Next →</a>
          {% endif %}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
