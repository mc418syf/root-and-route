<section class="newsletter section">
  <div class="wrap newsletter__inner">
    <div class="newsletter__content">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Stay in the loop' }}</p>
      <h2 class="newsletter__title">{{ section.settings.title | default: 'Seasonal Drops & Gifting Guides' }}</h2>
      <p class="newsletter__sub">{{ section.settings.subtitle | default: 'Be first to know about new collections, seasonal campaigns, and exclusive bundle offers.' }}</p>
    </div>
    <form class="newsletter__form" action="{{ routes.root_url }}" method="post" accept-charset="UTF-8">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter__field-group">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="newsletter-email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="your@email.com"
          required
          autocorrect="off"
          autocapitalize="off"
        >
        <button type="submit" class="btn btn--primary newsletter__submit">
          {{ section.settings.button_label | default: 'Subscribe' }}
        </button>
      </div>
      <p class="newsletter__disclaimer">No spam. Unsubscribe anytime. Thoughtful emails only.</p>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "title", "label": "Title", "default": "Seasonal Drops & Gifting Guides" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Be first to know about new collections, seasonal campaigns, and exclusive bundle offers." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
