<section class="section">
  <div class="wrap" style="max-width:760px;">
    <h1 style="font-family:var(--rr-serif);font-weight:300;font-size:clamp(2rem,4vw,2.8rem);color:var(--rr-ink);margin-bottom:32px;">{{ page.title }}</h1>
    <div class="rte" style="font-family:var(--rr-sans);font-size:15px;line-height:1.8;color:rgba(20,20,20,.75);">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
