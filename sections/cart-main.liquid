<section class="section">
  <div class="wrap" style="max-width:900px;">
    <h1 style="font-family:var(--rr-serif);font-weight:300;font-size:2.2rem;color:var(--rr-ink);margin-bottom:40px;">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div style="text-align:center;padding:80px 24px;border:1px solid var(--rr-border);border-radius:4px;background:var(--rr-paper);">
        <div style="color:var(--rr-forest);opacity:.4;margin-bottom:24px;">{% render 'icon-leaf', width: 48, height: 60 %}</div>
        <p style="font-family:var(--rr-serif);font-size:1.4rem;color:var(--rr-ink);margin-bottom:16px;">Your cart is empty</p>
        <p style="font-family:var(--rr-sans);font-size:14px;color:var(--rr-muted);margin-bottom:28px;">Discover our curated gift collections.</p>
        <a href="{{ routes.root_url }}/collections/all" class="btn btn--primary">Shop Now</a>
      </div>
    {% else %}
      <form action="/cart" method="post">
        {% for item in cart.items %}
          <div style="display:grid;grid-template-columns:100px 1fr auto;gap:24px;align-items:center;padding:24px 0;border-bottom:1px solid var(--rr-border);">
            <a href="{{ item.url }}">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="100" height="125" style="border-radius:3px;object-fit:cover;display:block;">
              {% endif %}
            </a>
            <div>
              <a href="{{ item.url }}" style="font-family:var(--rr-serif);font-weight:300;font-size:1.1rem;color:var(--rr-ink);">{{ item.product.title }}</a>
              {% if item.variant.title != 'Default Title' %}
                <p style="font-family:var(--rr-sans);font-size:12px;color:var(--rr-muted);margin-top:4px;">{{ item.variant.title }}</p>
              {% endif %}
              <p style="font-family:var(--rr-sans);font-size:14px;color:var(--rr-forest);margin-top:8px;">{{ item.price | money }}</p>
              <div style="display:flex;align-items:center;gap:12px;margin-top:12px;">
                <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" style="width:28px;height:28px;border:1px solid var(--rr-border);border-radius:2px;display:flex;align-items:center;justify-content:center;font-family:var(--rr-sans);color:var(--rr-ink);">−</a>
                <span style="font-family:var(--rr-sans);font-size:14px;min-width:24px;text-align:center;">{{ item.quantity }}</span>
                <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" style="width:28px;height:28px;border:1px solid var(--rr-border);border-radius:2px;display:flex;align-items:center;justify-content:center;font-family:var(--rr-sans);color:var(--rr-ink);">+</a>
                <a href="/cart/change?id={{ item.key }}&quantity=0" style="font-family:var(--rr-sans);font-size:12px;color:var(--rr-muted);margin-left:8px;">Remove</a>
              </div>
            </div>
            <div style="font-family:var(--rr-sans);font-weight:500;color:var(--rr-ink);">{{ item.line_price | money }}</div>
          </div>
        {% endfor %}

        <div style="display:flex;justify-content:flex-end;margin-top:32px;">
          <div style="min-width:280px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
              <span style="font-family:var(--rr-sans);font-size:14px;color:var(--rr-muted);">Subtotal</span>
              <span style="font-family:var(--rr-sans);font-size:14px;font-weight:500;color:var(--rr-ink);">{{ cart.total_price | money }}</span>
            </div>
            <p style="font-family:var(--rr-sans);font-size:12px;color:var(--rr-muted);margin-bottom:20px;">Shipping & taxes calculated at checkout</p>
            <button type="submit" name="checkout" class="btn btn--primary" style="width:100%;text-align:center;">Checkout</button>
          </div>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
