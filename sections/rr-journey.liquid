<section class="rr-section rr-section--paper">
  <div class="rr-container">
    {% render 'rr-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, center: true %}
    <div class="rr-timeline">
      {% for block in section.blocks %}
        <div class="rr-timeline__item rr-reveal" {{ block.shopify_attributes }}>
          <div class="rr-timeline__num">{{ block.settings.number }}</div>
          <div>
            <h3 class="rr-h3">{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collaborative journey",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The collaborative journey" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From root story to finished route." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A clear custom packaging process designed for international B2B communication and grounded production standards." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Discovery & Briefing" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "We define the product, audience, shelf context, quantity, timing, and brand story beneath the brief." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collaborative journey",
      "blocks": [
        { "type": "step", "settings": { "number": "01", "title": "Discovery & Briefing" } },
        { "type": "step", "settings": { "number": "02", "title": "Tactile Concepts & Structural Design", "text": "We translate your story into material mood, opening behavior, architecture, and unboxing rhythm." } },
        { "type": "step", "settings": { "number": "03", "title": "Prototyping & Material Selection", "text": "Samples refine paper, finish, color, closure, texture, and performance before production." } },
        { "type": "step", "settings": { "number": "04", "title": "Artisan Production & Logistics", "text": "We align factory craft, quality standards, international communication, and global delivery." } }
      ]
    }
  ]
}
{% endschema %}
