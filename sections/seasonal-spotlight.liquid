<section class="seasonal section">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Seasonal Collections' }}</p>
      <h2 class="section-head__title">{{ section.settings.title | default: 'Made for the Moment' }}</h2>
      <p class="section-head__sub">{{ section.settings.subtitle | default: 'Curated gifting sets for every season, celebration, and occasion.' }}</p>
    </div>

    <div class="seasonal-grid">
      {%- for block in section.blocks -%}
        <div class="seasonal-card" {{ block.shopify_attributes }}>
          <div class="seasonal-card__media">
            {%- if block.settings.image -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              <div class="seasonal-card__placeholder seasonal-card__placeholder--{{ forloop.index }}">
                {% render 'icon-leaf', width: 40, height: 50 %}
              </div>
            {%- endif -%}
          </div>
          <div class="seasonal-card__body">
            <p class="eyebrow">{{ block.settings.eyebrow }}</p>
            <h3 class="seasonal-card__title">{{ block.settings.title }}</h3>
            <p class="seasonal-card__text">{{ block.settings.text }}</p>
            {%- if block.settings.cta_label != blank -%}
              <a href="{{ block.settings.cta_url | default: '/collections/seasonal' }}" class="btn btn--text">
                {{ block.settings.cta_label }} →
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Seasonal Spotlight",
  "tag": "section",
  "blocks": [
    {
      "type": "season",
      "name": "Season Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Holiday" },
        { "type": "text", "id": "title", "label": "Title", "default": "Holiday Gift Sets" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Premium advent calendars and curated bundles for the gifting season." },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Holiday" },
        { "type": "url", "id": "cta_url", "label": "Button link" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Seasonal Collections" },
    { "type": "text", "id": "title", "label": "Title", "default": "Made for the Moment" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Curated gifting sets for every season, celebration, and occasion." }
  ],
  "presets": [
    {
      "name": "Seasonal Spotlight",
      "blocks": [
        { "type": "season", "settings": { "eyebrow": "Holiday", "title": "Holiday Gift Sets", "text": "Advent calendars and curated bundles for the gifting season.", "cta_label": "Shop Holiday" } },
        { "type": "season", "settings": { "eyebrow": "Wedding & Events", "title": "Wedding Favour Packaging", "text": "Elegant ribbon sets, favour boxes, and custom presentation for your big day.", "cta_label": "Shop Wedding" } },
        { "type": "season", "settings": { "eyebrow": "Corporate Gifting", "title": "Branded Gift Experiences", "text": "Elevate your corporate gifts with premium, FSC-certified packaging bundles.", "cta_label": "Shop Corporate" } }
      ]
    }
  ]
}
{% endschema %}
