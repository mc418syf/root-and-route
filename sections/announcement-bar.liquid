<div class="announcement-bar" role="region" aria-label="Announcement">
  <p class="announcement-bar__message">
    {{ section.settings.text | default: '🌿 FSC-Certified Paper Artistry — Free shipping on orders over $65 CAD' }}
  </p>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "🌿 FSC-Certified Paper Artistry — Free shipping on orders over $65 CAD"
    }
  ]
}
{% endschema %}
