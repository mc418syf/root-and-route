<section class="rr-hero">
  <div class="rr-container rr-hero__inner">
    <div class="rr-hero__copy">
      <div class="rr-eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="rr-h1">{{ section.settings.heading }}</h1>
      <div class="rr-hero__rule"></div>
      <div class="rr-subline">{{ section.settings.subheading }}</div>
      <p class="rr-intro">{{ section.settings.text }}</p>
      <div class="rr-hero__actions">
        <a class="rr-button" href="{{ section.settings.primary_url | default: '/pages/contact' }}">{{ section.settings.primary_label }}</a>
        <a class="rr-button rr-button--secondary" href="{{ section.settings.secondary_url | default: '/pages/portfolio' }}">{{ section.settings.secondary_label }}</a>
      </div>
    </div>
    <div class="rr-hero__visual">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'eager', alt: section.settings.image.alt }}
      {% else %}
        {% render 'rr-placeholder' %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rooted hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Root & Route Creations Inc." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Uncovering the roots. Creating the routes." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Eco-luxury packaging for beauty, fragrance, and lifestyle brands." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Every product begins with an idea. Every idea begins with a story. We uncover the root beneath the brand, then design the route that carries it onto shelves, into homes, and into people's hearts." },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Start an inquiry" },
    { "type": "url", "id": "primary_url", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "Explore portfolio" },
    { "type": "url", "id": "secondary_url", "label": "Secondary link" }
  ],
  "presets": [
    { "name": "Rooted hero" }
  ]
}
{% endschema %}
