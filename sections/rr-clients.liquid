<section class="rr-section">
  <div class="rr-container">
    {% render 'rr-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, center: true %}
    <div class="rr-clients">
      {% for block in section.blocks %}
        <div class="rr-client" {{ block.shopify_attributes }}>{{ block.settings.name }}</div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Client names",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trusted by visionary brands" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Across beauty, fragrance, gifting, and lifestyle." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A quiet client wall designed as typography: clean, grayscale, and confidence-building." }
  ],
  "blocks": [
    {
      "type": "client",
      "name": "Client",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Mentholatum" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Client names",
      "blocks": [
        { "type": "client", "settings": { "name": "Mentholatum" } },
        { "type": "client", "settings": { "name": "Disney" } },
        { "type": "client", "settings": { "name": "UEFA European League" } },
        { "type": "client", "settings": { "name": "Lido" } },
        { "type": "client", "settings": { "name": "Glo" } },
        { "type": "client", "settings": { "name": "Harrods" } }
      ]
    }
  ]
}
{% endschema %}
