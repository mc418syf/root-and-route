<section class="hero {% if section.settings.image %}hero--has-image{% else %}hero--no-image{% endif %}">
  {%- if section.settings.image -%}
    <div class="hero__media">
      {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', alt: section.settings.image.alt | escape }}
      <div class="hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="hero__content">
    <p class="eyebrow {% if section.settings.image %}eyebrow--light{% endif %}" style="margin-bottom:20px;">
      {{ section.settings.eyebrow | default: 'B2B Luxury Packaging' }}
    </p>

    <div class="hero__lockup">
      <span style="color:{% if section.settings.image %}var(--rr-sage){% else %}var(--rr-forest){% endif %};">
        {% render 'icon-leaf', width: 36, height: 46 %}
      </span>
      <h1 class="hero__wordmark">Root <em>&</em> Route</h1>
    </div>

    <p class="hero__creations" style="margin-top:14px;letter-spacing:.4em;">
      {{ section.settings.sub_eyebrow | default: 'CREATIONS INC.' }}
    </p>

    <div class="hero__rule"></div>

    <p class="hero__tagline">
      {{ section.settings.tagline | default: 'Every package is a conversation between a brand and its audience.' }}
    </p>

    <p class="hero__subtext">
      {{ section.settings.body | default: 'We uncover the root of every brand. Then we design the route — the one that leads your story onto shelves, into homes, and into people's hearts.' }}
    </p>

    <div class="hero__actions">
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn {% if section.settings.image %}btn--outline-light{% else %}btn--primary{% endif %}">
        {{ section.settings.cta_label | default: 'Explore Collections' }}
      </a>
      <a href="{{ section.settings.cta2_url | default: '/pages/contact' }}" class="btn btn--secondary {% if section.settings.image %}btn--outline-light{% endif %}">
        {{ section.settings.cta2_label | default: 'Start a Project' }}
      </a>
    </div>

    <div class="hero__badges">
      <span class="hero__badge">FSC Certified</span>
      <span class="hero__badge">Disney Certified Supplier</span>
      <span class="hero__badge">18+ Years of Craft</span>
      <span class="hero__badge">Guangzhou · Global Delivery</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "B2B Luxury Packaging" },
    { "type": "text", "id": "sub_eyebrow", "label": "Sub-eyebrow", "default": "CREATIONS INC." },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Every package is a conversation between a brand and its audience." },
    { "type": "textarea", "id": "body", "label": "Body copy" },
    { "type": "text", "id": "cta_label", "label": "CTA 1 label", "default": "Explore Collections" },
    { "type": "url", "id": "cta_url", "label": "CTA 1 link" },
    { "type": "text", "id": "cta2_label", "label": "CTA 2 label", "default": "Start a Project" },
    { "type": "url", "id": "cta2_url", "label": "CTA 2 link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
