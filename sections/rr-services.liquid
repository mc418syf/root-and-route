<section class="rr-section">
  <div class="rr-container">
    {% render 'rr-section-heading', eyebrow: section.settings.eyebrow, heading: section.settings.heading, text: section.settings.text, center: false %}
    <div class="rr-grid-3">
      {% for block in section.blocks %}
        <article class="rr-card rr-service" {{ block.shopify_attributes }}>
          <div class="rr-meta">{{ block.settings.meta }}</div>
          <h3 class="rr-h3">{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What we offer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Material aesthetics, structural engineering, and aligned global supply." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Root & Route combines the feeling of an atelier with the discipline of a production partner." }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "meta", "label": "Meta", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Material Innovation" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Selected sustainable art papers, specialty finishes, and tactile materials curated for brand expression." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services",
      "blocks": [
        { "type": "service", "settings": { "meta": "01", "title": "Material Innovation" } },
        { "type": "service", "settings": { "meta": "02", "title": "Structural Engineering", "text": "Opening resistance, magnetic snap, drawer movement, and full unboxing experience design." } },
        { "type": "service", "settings": { "meta": "03", "title": "Global Supply Alignment", "text": "B2B communication, production standards, conscious sourcing, certification support, and delivery coordination." } }
      ]
    }
  ]
}
{% endschema %}
