<section class="rr-section rr-section--paper">
  <div class="rr-container">
    <div class="rr-section-head rr-section-head--center">
      <div class="rr-eyebrow">{{ page.title }}</div>
      <h1 class="rr-h1">{{ page.title }}</h1>
    </div>
    <div style="max-width:820px;margin:0 auto;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page"
}
{% endschema %}
