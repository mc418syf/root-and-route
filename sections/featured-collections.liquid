<section class="featured-collections section">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Curated for you' }}</p>
      <h2 class="section-head__title">{{ section.settings.title | default: 'Shop by Collection' }}</h2>
    </div>

    <div class="collection-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <a href="{{ collection.url | default: '#' }}" class="collection-card" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if block.settings.image -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.label }}
            {%- elsif collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}
            {%- else -%}
              <div class="collection-card__placeholder">
                {% render 'icon-leaf', width: 48, height: 60 %}
              </div>
            {%- endif -%}
            <div class="collection-card__overlay"></div>
          </div>
          <div class="collection-card__body">
            <p class="collection-card__label">{{ block.settings.label | default: collection.title }}</p>
            <p class="collection-card__sub">{{ block.settings.sub }}</p>
            <span class="collection-card__cta">Explore →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Card label",
          "default": "Gift Sets"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Card subtitle",
          "default": "Curated bundles for every occasion"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Curated for you"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop by Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "label": "Gift Sets", "sub": "Coordinated bundles, beautifully presented" } },
        { "type": "collection_card", "settings": { "label": "Advent Calendars", "sub": "24 days of seasonal delight" } },
        { "type": "collection_card", "settings": { "label": "Ribbons & Accents", "sub": "The finishing touch that makes it memorable" } },
        { "type": "collection_card", "settings": { "label": "Cards & Stationery", "sub": "Thoughtfully crafted paper artistry" } }
      ]
    }
  ]
}
{% endschema %}
