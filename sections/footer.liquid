<footer class="rr-footer">
  <div class="rr-container">
    <div class="rr-footer__grid">
      <div>
        <div class="rr-eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 class="rr-h2" style="margin-top:14px;">{{ section.settings.heading }}</h2>
        <p class="rr-intro">{{ section.settings.text }}</p>
      </div>
      <div>
        <a class="rr-subline" href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
        <ul class="rr-menu" style="display:grid; gap:12px; margin-top:28px;">
          {% for link in section.settings.menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    <div class="rr-footer__bottom">
      {{ section.settings.bottom_text }}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Begin the route"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every package is a conversation between a brand and its audience."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "For beauty, fragrance, lifestyle, and gifting brands seeking tactile, sustainable packaging with a clear path to production."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@rootandroute.com"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "Root & Route Creations Inc. - Eco-luxury paper artistry and conscious packaging."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
