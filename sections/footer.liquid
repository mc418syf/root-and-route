<footer class="site-footer" role="contentinfo">
  <div class="wrap site-footer__inner">

    <div class="site-footer__brand">
      <a href="{{ routes.root_url }}" class="site-footer__logo" aria-label="{{ shop.name }}">
        <span style="color:var(--rr-sage);">{% render 'icon-leaf', width: 20, height: 26 %}</span>
        <span class="site-footer__wordmark">Root <em style="color:var(--rr-sage);">&</em> Route</span>
      </a>
      <p class="site-footer__tagline">Creations Inc. — Luxury B2B Packaging</p>
      <div class="site-footer__badges">
        <span class="badge">FSC Certified</span>
        <span class="badge">Disney Certified Supplier</span>
        <span class="badge">18+ Years of Craft</span>
      </div>
    </div>

    <nav class="site-footer__nav">
      <div class="site-footer__col">
        <p class="site-footer__col-title">Collections</p>
        <ul>
          <li><a href="/collections/frost">The Frost Collection</a></li>
          <li><a href="/collections/linear">The Linear Collection</a></li>
          <li><a href="/collections/monolith">The Monolith Collection</a></li>
          <li><a href="/collections/atelier">The Atelier Collection</a></li>
          <li><a href="/collections/all">View All</a></li>
        </ul>
      </div>
      <div class="site-footer__col">
        <p class="site-footer__col-title">Company</p>
        <ul>
          <li><a href="/pages/about">Our Manifesto</a></li>
          <li><a href="/pages/services">Services</a></li>
          <li><a href="/pages/process">The Journey</a></li>
          <li><a href="/pages/certifications">Certifications</a></li>
        </ul>
      </div>
      <div class="site-footer__col">
        <p class="site-footer__col-title">Work With Us</p>
        <ul>
          <li><a href="/pages/contact">Start a Project</a></li>
          <li><a href="mailto:hello@rootandroute.com">hello@rootandroute.com</a></li>
          <li><a href="/pages/contact">Request a Sample</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="site-footer__bottom">
    <p class="site-footer__copy">&copy; {{ 'now' | date: '%Y' }} Root &amp; Route Creations Inc. All rights reserved.</p>
    <p class="site-footer__location">Guangzhou, China · Serving brands worldwide</p>
  </div>
</footer>

{% schema %}
{ "name": "Footer", "settings": [] }
{% endschema %}
