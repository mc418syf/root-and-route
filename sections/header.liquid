<header class="rr-header">
  <div class="rr-container rr-nav">
    <a href="{{ routes.root_url }}">
      {% render 'rr-logo' %}
    </a>

    <button class="rr-mobile-toggle" type="button" aria-expanded="false" aria-controls="RootRouteMenu" data-rr-menu-toggle>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </button>

    <nav id="RootRouteMenu" aria-label="Primary">
      <ul class="rr-menu" data-rr-menu>
        {% for link in section.settings.menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% else %}
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="/pages/portfolio">Portfolio</a></li>
          <li><a href="/pages/services">Service</a></li>
          <li><a href="/pages/process">Process</a></li>
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Inquiry</a></li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
