<header class="site-header" role="banner">
  <div class="site-header__inner wrap">

    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      <span style="color:var(--rr-forest);">{% render 'icon-leaf', width: 20, height: 26 %}</span>
      <span class="site-header__wordmark">Root <em>&</em> Route</span>
    </a>

    <nav class="site-nav" role="navigation">
      <ul class="site-nav__list">
        <li><a href="/collections/all" class="site-nav__link">Collections</a></li>
        <li><a href="/pages/about" class="site-nav__link">About</a></li>
        <li><a href="/pages/services" class="site-nav__link">Services</a></li>
        <li><a href="/pages/process" class="site-nav__link">Process</a></li>
        <li>
          <a href="/pages/contact" class="btn btn--primary" style="padding:10px 24px;font-size:12px;margin-left:8px;">Start a Project</a>
        </li>
      </ul>
    </nav>

    <button class="site-header__menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" style="display:none;" aria-label="Mobile navigation">
    <ul class="mobile-nav__list">
      <li><a href="/collections/all">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/pages/services">Services</a></li>
      <li><a href="/pages/process">Process</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul>
  </nav>
</header>

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
