<section class="brand-story section section--dark">
  <div class="wrap brand-story__inner">
    <div class="brand-story__content">
      <p class="eyebrow eyebrow--light">{{ section.settings.eyebrow | default: 'Our Manifesto' }}</p>
      <h2 class="brand-story__title">{{ section.settings.title | default: 'Every product begins with an idea. Every idea begins with a story.' }}</h2>
      <p class="brand-story__body">{{ section.settings.body | default: 'Somewhere beneath every logo, every recipe, every founder, every business — there is a root. Our job isn\'t to invent it. It\'s to uncover it. Then we design the route. The route that leads your story onto shelves, into homes, and into people\'s hearts. Because packaging isn\'t the final step. It\'s the beginning of every customer\'s first impression.' }}</p>
      <a href="{{ section.settings.cta_url | default: '/pages/about' }}" class="btn btn--outline-light">{{ section.settings.cta_label | default: 'Our Philosophy' }}</a>
    </div>

    <div class="brand-story__pillars">
      {% for block in section.blocks %}
        <div class="pillar" {{ block.shopify_attributes }}>
          <div class="pillar__icon">{% render 'icon-leaf', width: 20, height: 26 %}</div>
          <div>
            <p class="pillar__title">{{ block.settings.title }}</p>
            <p class="pillar__body">{{ block.settings.body }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Manifesto" },
    { "type": "textarea", "id": "title", "label": "Headline" },
    { "type": "textarea", "id": "body", "label": "Body copy" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Our Philosophy" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [{
    "name": "Brand Story",
    "blocks": [
      { "type": "pillar", "settings": { "title": "Material Innovation", "body": "Sustainably sourced specialty papers with exceptional tactile quality. We curate materials the way a gallery curates art." } },
      { "type": "pillar", "settings": { "title": "Structural Engineering", "body": "The soft resistance of a magnetic close. The clean snap of a perfect lid. Every opening is choreographed." } },
      { "type": "pillar", "settings": { "title": "Global Supply Alignment", "body": "Seamless international communication and delivery standards from our Guangzhou facility to your door." } }
    ]
  }]
}
{% endschema %}
