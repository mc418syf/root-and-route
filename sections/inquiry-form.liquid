<section class="inquiry section" style="background:var(--rr-paper);">
  <div class="wrap" style="max-width:840px;">
    <div class="section-head">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Start a Project' }}</p>
      <h2 class="section-head__title">{{ section.settings.title | default: "Let's Build Something Together" }}</h2>
      <p class="section-head__sub">{{ section.settings.subtitle | default: "Tell us about your project. We'll respond within 2 business days." }}</p>
    </div>

    {%- form 'contact', id: 'inquiry-form' -%}
      {% if form.posted_successfully? %}
        <div class="inquiry__success">
          <div style="color:var(--rr-forest);margin-bottom:20px;">{% render 'icon-leaf', width: 32, height: 40 %}</div>
          <h3 style="font-family:var(--rr-serif);font-weight:300;font-size:1.6rem;color:var(--rr-ink);margin-bottom:12px;">Thank you. Your brief is with us.</h3>
          <p style="font-family:var(--rr-sans);font-size:14px;color:var(--rr-muted);">We'll be in touch within 2 business days.</p>
        </div>
      {% else %}

        <!-- Step 1: About your brand -->
        <div class="inquiry__section">
          <p class="inquiry__step-label">01 — About Your Brand</p>
          <div class="inquiry__grid">
            <div class="inquiry__field">
              <label for="contact[name]" class="inquiry__label">Your Name *</label>
              <input type="text" id="contact[name]" name="contact[name]" class="inquiry__input" required placeholder="Jane Smith">
            </div>
            <div class="inquiry__field">
              <label for="contact[company]" class="inquiry__label">Brand / Company *</label>
              <input type="text" id="contact[company]" name="contact[company]" class="inquiry__input" required placeholder="Acme Beauty">
            </div>
            <div class="inquiry__field">
              <label for="contact[email]" class="inquiry__label">Email *</label>
              <input type="email" id="contact[email]" name="contact[email]" class="inquiry__input" required placeholder="jane@brand.com">
            </div>
            <div class="inquiry__field">
              <label for="contact[country]" class="inquiry__label">Country</label>
              <input type="text" id="contact[country]" name="contact[country]" class="inquiry__input" placeholder="Canada">
            </div>
          </div>
        </div>

        <!-- Step 2: Project details -->
        <div class="inquiry__section">
          <p class="inquiry__step-label">02 — Project Scope</p>

          <div class="inquiry__field" style="margin-bottom:24px;">
            <label class="inquiry__label">Estimated Quantity</label>
            <div class="inquiry__options">
              {% assign quantities = "Under 500 units|500–2,000 units|2,000–10,000 units|10,000+ units" | split: "|" %}
              {% for q in quantities %}
                <label class="inquiry__option">
                  <input type="radio" name="contact[quantity]" value="{{ q }}">
                  <span>{{ q }}</span>
                </label>
              {% endfor %}
            </div>
          </div>

          <div class="inquiry__field" style="margin-bottom:24px;">
            <label class="inquiry__label">Material Aesthetic</label>
            <div class="inquiry__options">
              {% assign materials = "Matte / Frosted|Glossy / Lacquered|Textured / Embossed|Natural / Kraft|Luxury Board|Unsure — advise me" | split: "|" %}
              {% for m in materials %}
                <label class="inquiry__option">
                  <input type="checkbox" name="contact[material][]" value="{{ m }}">
                  <span>{{ m }}</span>
                </label>
              {% endfor %}
            </div>
          </div>

          <div class="inquiry__field" style="margin-bottom:24px;">
            <label class="inquiry__label">Custom Structure Needed?</label>
            <div class="inquiry__options">
              {% assign structures = "Standard box|Magnetic closure|Drawer / Slide box|Rigid book box|Custom — open to ideas" | split: "|" %}
              {% for s in structures %}
                <label class="inquiry__option">
                  <input type="radio" name="contact[structure]" value="{{ s }}">
                  <span>{{ s }}</span>
                </label>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Step 3: Message -->
        <div class="inquiry__section">
          <p class="inquiry__step-label">03 — Your Brief</p>
          <div class="inquiry__field">
            <label for="contact[body]" class="inquiry__label">Tell us about your project *</label>
            <textarea id="contact[body]" name="contact[body]" class="inquiry__input inquiry__textarea" rows="5" required placeholder="Describe your product, the feeling you want the packaging to evoke, any references or inspiration, and your timeline..."></textarea>
          </div>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-top:8px;">
          <p style="font-family:var(--rr-sans);font-size:12px;color:var(--rr-muted);">We treat every brief with complete confidentiality.</p>
          <button type="submit" class="btn btn--primary" style="padding:14px 40px;">Submit Brief →</button>
        </div>
      {% endif %}
    {%- endform -%}
  </div>
</section>

<style>
.inquiry__section {
  border: 1px solid var(--rr-border);
  border-radius: 4px;
  padding: 32px;
  margin-bottom: 20px;
  background: #fff;
}
.inquiry__step-label {
  font-family: var(--rr-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--rr-forest);
  margin-bottom: 24px;
}
.inquiry__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.inquiry__label {
  display: block;
  font-family: var(--rr-sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .04em;
  color: var(--rr-ink);
  margin-bottom: 8px;
}
.inquiry__input {
  width: 100%;
  font-family: var(--rr-sans);
  font-size: 14px;
  padding: 12px 16px;
  border: 1px solid var(--rr-stone);
  border-radius: 2px;
  background: var(--rr-paper);
  color: var(--rr-ink);
  outline: none;
  transition: border-color .15s;
}
.inquiry__input:focus { border-color: var(--rr-forest); background: #fff; }
.inquiry__textarea { resize: vertical; min-height: 120px; }
.inquiry__options {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.inquiry__option {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}
.inquiry__option input { accent-color: var(--rr-forest); }
.inquiry__option span {
  font-family: var(--rr-sans);
  font-size: 13px;
  color: var(--rr-ink);
  border: 1px solid var(--rr-border);
  border-radius: 20px;
  padding: 6px 16px;
  transition: border-color .15s, background .15s;
}
.inquiry__option input:checked + span {
  border-color: var(--rr-forest);
  background: rgba(47,94,58,.06);
  color: var(--rr-forest);
}
.inquiry__success {
  text-align: center;
  padding: 80px 40px;
  border: 1px solid var(--rr-border);
  border-radius: 4px;
  background: #fff;
}
@media (max-width: 640px) {
  .inquiry__grid { grid-template-columns: 1fr; }
  .inquiry__section { padding: 24px 20px; }
}
</style>

{% schema %}
{
  "name": "Inquiry Form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start a Project" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Let's Build Something Together" },
    { "type": "text", "id": "subtitle", "label": "Subheading" }
  ],
  "presets": [{ "name": "Inquiry Form" }]
}
{% endschema %}
