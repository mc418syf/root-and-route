<section class="section">
  <div class="wrap">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;">
      <!-- Gallery -->
      <div>
        {% if product.featured_image %}
          <div style="border-radius:4px;overflow:hidden;aspect-ratio:4/5;background:var(--rr-paper);">
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" width="800" height="1000" style="width:100%;height:100%;object-fit:cover;">
          </div>
          {% if product.images.size > 1 %}
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;">
              {% for image in product.images limit: 4 %}
                <div style="aspect-ratio:1;overflow:hidden;border-radius:2px;border:1px solid var(--rr-border);">
                  <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}" width="200" height="200" style="width:100%;height:100%;object-fit:cover;">
                </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>

      <!-- Info -->
      <div>
        {% if section.settings.show_vendor and product.vendor != blank %}
          <p class="eyebrow" style="margin-bottom:12px;">{{ product.vendor }}</p>
        {% endif %}
        <h1 style="font-family:var(--rr-serif);font-weight:300;font-size:2rem;color:var(--rr-ink);margin-bottom:16px;">{{ product.title }}</h1>
        <p style="font-family:var(--rr-sans);font-size:1.2rem;color:var(--rr-forest);margin-bottom:24px;">{{ product.price | money }}</p>

        {% if product.description != blank %}
          <div style="font-family:var(--rr-sans);font-size:14px;line-height:1.75;color:rgba(20,20,20,.7);margin-bottom:32px;">
            {{ product.description }}
          </div>
        {% endif %}

        <form method="post" action="/cart/add">
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">

          {% if product.variants.size > 1 %}
            <div style="margin-bottom:24px;">
              <label style="font-family:var(--rr-sans);font-size:12px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--rr-ink);display:block;margin-bottom:8px;">Option</label>
              <select name="id" style="width:100%;padding:12px 16px;border:1px solid var(--rr-stone);border-radius:2px;font-family:var(--rr-sans);font-size:14px;color:var(--rr-ink);background:#fff;">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }}{% unless variant.available %} — Sold Out{% endunless %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {% endif %}

          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <button type="submit" class="btn btn--primary" {% unless product.available %}disabled style="opacity:.5;cursor:not-allowed;"{% endunless %}>
              {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>
            <a href="{{ routes.root_url }}/collections/all" class="btn btn--secondary">Continue Shopping</a>
          </div>
        </form>

        {% if section.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
          <p style="font-family:var(--rr-sans);font-size:11px;color:var(--rr-muted);margin-top:20px;letter-spacing:.04em;">SKU: {{ product.selected_or_first_available_variant.sku }}</p>
        {% endif %}

        <!-- Trust badges -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:28px;padding-top:28px;border-top:1px solid var(--rr-border);">
          <span class="badge" style="border:1px solid var(--rr-border);border-radius:20px;padding:5px 14px;font-family:var(--rr-sans);font-size:11px;letter-spacing:.04em;color:var(--rr-muted);">FSC Certified</span>
          <span class="badge" style="border:1px solid var(--rr-border);border-radius:20px;padding:5px 14px;font-family:var(--rr-sans);font-size:11px;letter-spacing:.04em;color:var(--rr-muted);">Disney Certified Supplier</span>
          <span class="badge" style="border:1px solid var(--rr-border);border-radius:20px;padding:5px 14px;font-family:var(--rr-sans);font-size:11px;letter-spacing:.04em;color:var(--rr-muted);">18+ Years of Craft</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_sku", "label": "Show SKU", "default": true }
  ]
}
{% endschema %}
