      },
      {
        "type": "select",
        "id": "vertical_spacing_between_sections",
        "label": "Vertical spacing between sections",
        "default": "86px",
        "options": [
          { "value": "64px", "label": "Compact" },
          { "value": "86px", "label": "Comfortable" },
          { "value": "112px", "label": "Editorial" }
        ]
      },
      {
        "type": "radio",
        "id": "section_titles_position",
