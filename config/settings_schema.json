  {
    "name": "Typography",
    "settings": [
      {
        "type": "range",
        "id": "base_font_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "range",
        "id": "base_line_height",
        "label": "Base line height",
        "min": 1.3,
        "max": 1.9,
        "step": 0.1,
        "default": 1.6
      },
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading text transform",
        "default": "none",
        "options": [
          { "value": "none", "label": "None" },
          { "value": "uppercase", "label": "Uppercase" }
        ]
      },
      {
        "type": "select",
        "id": "heading_scale",
        "label": "Heading scale",
        "default": "editorial",
        "options": [
          { "value": "quiet", "label": "Quiet" },
          { "value": "editorial", "label": "Editorial" },
          { "value": "large", "label": "Large" }
        ]
      },
      {
        "type": "range",
        "id": "eyebrow_letter_spacing",
        "label": "Eyebrow letter spacing",
        "min": 0.12,
        "max": 0.36,
        "step": 0.02,
        "default": 0.28
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Page width",
        "default": "1180px",
        "options": [
          { "value": "1080px", "label": "Narrow" },
          { "value": "1180px", "label": "Standard" },
          { "value": "1320px", "label": "Wide" }
