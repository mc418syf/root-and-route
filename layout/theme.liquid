<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_forest }}">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    {{ 'root-route.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'root-route.js' | asset_url }}" defer></script>

    <style>
      :root {
        --rr-paper: {{ settings.color_paper }};
        --rr-ink: {{ settings.color_ink }};
        --rr-forest: {{ settings.color_forest }};
        --rr-sage: {{ settings.color_sage }};
        --rr-stone: {{ settings.color_stone }};
        --rr-border: {{ settings.color_border }};
        --rr-butter: {{ settings.color_butter }};
        --rr-muted: {{ settings.color_muted }};
        --rr-base-font-size: {{ settings.base_font_size }}px;
        --rr-base-line-height: {{ settings.base_line_height }};
        --rr-max: {{ settings.page_width }};
        --rr-section-space: {{ settings.vertical_spacing_between_sections }};
        --rr-button-radius: {{ settings.button_border_radius }};
        --rr-button-transform: {{ settings.button_text_transform }};
        --rr-card-radius: {{ settings.card_border_radius }};
        --rr-media-radius: {{ settings.media_border_radius }};
        --rr-product-ratio: {{ settings.product_tiles_aspect_ratio }};
        --rr-eyebrow-spacing: {{ settings.eyebrow_letter_spacing }}em;
        --rr-animation-duration: {{ settings.animation_duration }}ms;
      }

      {% if settings.enable_smooth_scroll == false %}
        html { scroll-behavior: auto; }
      {% endif %}

      {% if settings.show_leaf_motif == false %}
        .rr-hero,
        .rr-section--dark {
          background-image: none !important;
        }
      {% endif %}

      {% if settings.cascade_fade_in_items == false %}
        .rr-reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      {% endif %}

      {% case settings.heading_scale %}
        {% when 'quiet' %}
          :root { --rr-h1-max: 5.4rem; --rr-h2-max: 3.4rem; }
        {% when 'large' %}
          :root { --rr-h1-max: 7.6rem; --rr-h2-max: 5rem; }
        {% else %}
          :root { --rr-h1-max: 6.8rem; --rr-h2-max: 4.3rem; }
      {% endcase %}

      {% if settings.heading_text_transform != 'none' %}
        .rr-h1,
        .rr-h2,
        .rr-h3 {
          text-transform: {{ settings.heading_text_transform }};
        }
      {% endif %}
    </style>
  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">Skip to content</a>
    {% sections 'header-group' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </body>
</html>
