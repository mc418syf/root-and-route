<div class="rr-section-head{% if center %} rr-section-head--center{% endif %}">
  {% if eyebrow != blank %}
    <div class="rr-eyebrow">{{ eyebrow }}</div>
  {% endif %}
  {% if heading != blank %}
    <h2 class="rr-h2">{{ heading }}</h2>
  {% endif %}
  {% if text != blank %}
    <p class="rr-intro">{{ text }}</p>
  {% endif %}
</div>
